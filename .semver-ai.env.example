# SemVer AI Tool - Environment Variables Template
# ================================================
# Copy this file to .semver-ai.env and fill in your values.
# IMPORTANT: NEVER commit this file with real credentials!

# Groq API Configuration
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model configuration (optional - defaults to llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# API endpoint (optional - don't change unless you know what you're doing)
GROQ_URL=https://api.groq.com/openai/v1/chat/completions