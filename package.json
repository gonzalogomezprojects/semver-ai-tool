{
  "name": "semver-ai-tool",
  "version": "1.3.0",
  "description": "AI-powered CLI for Semantic Versioning and Automated Release Notes using LLaMA 3.3.",
  "main": "src/cli.sh",
  "bin": {
    "semver-ai": "./src/cli.sh"
  },
  "files": [
    "src",
    "docs",
    "LICENSE",
    "README.md",
    "README.es.md"
  ],
  "scripts": {
    "publish:patch": "npm version patch && npm publish",
    "publish:minor": "npm version minor && npm publish",
    "publish:major": "npm version major && npm publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gonzalogomezprojects/semver-ai-tool.git"
  },
  "keywords": [
    "semver",
    "ai",
    "conventional-commits",
    "cli",
    "release",
    "groq",
    "llama"
  ],
  "author": "Gonzalo S. A. Gomez (Sarit Startups)",
  "homepage": "https://semveraitool.saritstartups.com.ar/",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  }
}
